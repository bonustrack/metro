{
  "name": "@metro-labs/metro",
  "version": "0.1.0-beta.15",
  "private": false,
  "description": "Event-interception wire. Supervises train subprocesses in ~/.metro/trains/, multiplexes their JSON event stream onto stdout, and routes outbound action calls back via stdin. Per-platform code is written by the agent (or user) as train scripts — metro core is pure transport.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bonustrack/metro.git"
  },
  "homepage": "https://github.com/bonustrack/metro#readme",
  "bugs": "https://github.com/bonustrack/metro/issues",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "metro-daemon": "./dist/server.js"
  },
  "exports": {
    ".": "./src/mcp/index.ts",
    "./server": "./dist/server.js",
    "./define-train": "./dist/define-train.js",
    "./schema": "./dist/schema.js"
  },
  "files": [
    "dist",
    "src/mcp",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun src/server.ts",
    "build": "tsc",
    "prepublishOnly": "tsc",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "tsc && METRO_STATE_DIR=\"$(mktemp -d /tmp/metro-test.XXXXXX)\" bun test test/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xmtp/content-type-primitives": "^3.0.1",
    "@xmtp/content-type-reaction": "^2.0.2",
    "@xmtp/content-type-remote-attachment": "^2.0.4",
    "@xmtp/content-type-reply": "^2.0.3",
    "@xmtp/content-type-transaction-reference": "^2.0.2",
    "@xmtp/content-type-wallet-send-calls": "^2.0.0",
    "@xmtp/node-sdk": "^6.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "viem": "^2.52.2",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.3.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "bun@1.3.9"
}
