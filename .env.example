# Metro runtime config. Copy to .env and fill in.
#
# Accounts come from Postgres — set DATABASE_URL. The station account secrets
# (MNEMONIC, TELEGRAM_BOT_TOKENS, ...) are NOT read at runtime; they are only
# consumed once by the seed script to populate the DB (see the one-time seed
# section below and README "Database / multi-agent").

# ----- Database (required) -----
# Cloud Postgres connection string. Accounts + agents load from here on boot.
DATABASE_URL=postgres://user:pass@host:5432/metro
# Which agent this daemon serves (name or id). Unset = all agents in the DB.
# METRO_AGENT=Tony

# ----- Server (optional) -----
# The MCP runs in-process at the root path, http://127.0.0.1:8420 — no token needed.
# Optional bearer to gate the MCP endpoint for external clients. This same token
# also gates the lightweight Monitor transport (live-only /api/tail SSE,
# /api/call/<train>/<action>, /api/health) — reachable with the same ?token=
# (or Bearer). Leave unset to keep both the MCP endpoint open and the /api/*
# surface disabled (404). Generate:
#   openssl rand -hex 32
# METRO_MCP_HTTP_TOKEN=
# Public base URL the daemon is reachable at (e.g. https://mcp.metro.box). When set,
# inbound attachments that have no upstream CDN url (Telegram user/bot, XMTP) are
# surfaced to agents as a token-gated `${METRO_PUBLIC_URL}/attach/<file>?token=...`
# link they can fetch, instead of a daemon-local path they cannot reach. Falls back
# to the cloudflared tunnel hostname when unset; leave unset for a purely local setup.
# METRO_PUBLIC_URL=
# Log verbosity. One of: trace | debug | info | warn | error | fatal. Default: info.
# Logs go to stderr.
METRO_LOG_LEVEL=

# ----- One-time seed (NOT runtime) -----
# The db:seed script reads these once to load your current setup into Postgres,
# then you drop them. They are never read when the daemon runs.
#   MNEMONIC=            BIP-39 mnemonic; HD accounts derive at m/44'/60'/0'/0/<i>
#   DERIVE_COUNT=1       how many XMTP HD accounts to derive (ids x0..xN)
#   TELEGRAM_BOT_TOKENS= comma-separated @BotFather tokens (ids t0..tN)
#   DISCORD_BOT_TOKENS=  comma-separated bot tokens (ids d0..dN); enable the
#                        Message Content Intent or messageCreate content is empty
#   TELEGRAM_USER_SESSION= / TELEGRAM_USER_API_ID= / TELEGRAM_USER_API_HASH=
#   METRO_MCP_HTTP_TOKEN= stored as the agent's key
