# Configure at least one station (XMTP, Telegram, Discord). Copy to .env and fill in.

# ----- XMTP -----
# Identity is an Ethereum EOA. Derive account(s) from a BIP-39 mnemonic, or use a
# raw private key. Raw key wins when set; otherwise accounts derive from the mnemonic.
XMTP_MNEMONIC=
# Or point at a file holding the mnemonic (default ~/.metro/xmtp-mnemonic, 0600):
# XMTP_MNEMONIC_FILE=
# Which HD indices to derive (m/44'/60'/0'/0/<index>). INDICES wins over COUNT.
# XMTP_DERIVE_INDICES=0,1,2
# XMTP_DERIVE_COUNT=3
# Back-compat single raw key → one `default` account:
# XMTP_PRIVATE_KEY=
# production | dev | local (default production)
# XMTP_ENV=

# ----- Telegram -----
# One bot: a token from @BotFather. Many bots: comma-separate the tokens.
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_TOKENS=token1,token2
# Optional account ids per token (else t0..tN, or `default` for one):
# TELEGRAM_BOT_IDS=alpha,beta

# ----- Discord -----
# One bot: a token from https://discord.com/developers/applications.
# Many bots: comma-separate the tokens.
# In the Bot tab → Privileged Gateway Intents, enable **Message Content Intent**
# — without it, messageCreate events arrive with empty content.
DISCORD_BOT_TOKEN=
# DISCORD_BOT_TOKENS=token1,token2
# Optional account ids per token (else d0..dN, or `default` for one):
# DISCORD_BOT_IDS=alpha,beta

# ----- Optional -----
# Log verbosity. One of: trace | debug | info | warn | error | fatal. Default: info.
# Logs go to stderr.
METRO_LOG_LEVEL=
