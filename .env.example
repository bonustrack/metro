# Metro runtime config. Copy to .env and fill in.
#
# Accounts come from Postgres — the daemon reads agents + accounts from the database
# on boot and materializes the per-station account files the trains read. Set
# DATABASE_URL; populate the agents/accounts tables directly (see README
# "Database / multi-agent"). No account secrets are ever read from the environment.

# ----- Database (required) -----
# Cloud Postgres connection string. Accounts + agents load from here on boot.
DATABASE_URL=postgres://user:pass@host:5432/metro
# Which agent this daemon serves (by name). Unset = all agents in the DB.
# METRO_AGENT=Tony

# ----- Server (optional) -----
# The MCP runs in-process at the root path, http://127.0.0.1:8420 — no token needed.
# Optional bearer to gate the MCP endpoint for external clients. This same token
# also gates the lightweight Monitor transport (live-only /api/tail SSE,
# /api/call/<train>/<action>, /api/health) — reachable with the same ?token=
# (or Bearer). Leave unset to keep both the MCP endpoint open and the /api/*
# surface disabled (404). Generate:
#   openssl rand -hex 32
# METRO_MCP_HTTP_TOKEN=
# Public base URL the daemon is reachable at (e.g. https://mcp.metro.box). When set,
# inbound attachments that have no upstream CDN url (Telegram user/bot, XMTP) are
# surfaced to agents as a token-gated `${METRO_PUBLIC_URL}/attach/<file>?token=...`
# link they can fetch, instead of a daemon-local path they cannot reach. When unset,
# uses the cloudflared tunnel hostname; leave unset for a purely local setup.
# METRO_PUBLIC_URL=
# Log verbosity. One of: trace | debug | info | warn | error | fatal. Default: info.
# Logs go to stderr.
METRO_LOG_LEVEL=
