# Configure at least one station (XMTP, Telegram, Discord). Copy to .env and fill in.

# ----- XMTP -----
# Identity is one or more Ethereum EOAs derived from a BIP-39 mnemonic
# (m/44'/60'/0'/0/<index>). Always runs on the production XMTP network.
MNEMONIC=
# How many HD accounts to derive (indices 0..N-1). Default: 1.
# DERIVE_COUNT=1

# ----- Telegram -----
# Comma-separate one bot token per bot (from @BotFather). Account ids are t0..tN.
TELEGRAM_BOT_TOKENS=

# ----- Discord -----
# Comma-separate one bot token per bot
# (https://discord.com/developers/applications). Account ids are d0..dN.
# In the Bot tab → Privileged Gateway Intents, enable **Message Content Intent**
# — without it, messageCreate events arrive with empty content.
DISCORD_BOT_TOKENS=

# ----- Optional -----
# The MCP runs in-process at the root path, http://127.0.0.1:8420 — no token needed.
# Optional bearer to gate the MCP endpoint for external clients. This same token
# also gates the lightweight Monitor transport (live-only /api/tail SSE,
# /api/call/<train>/<action>, /api/health) — reachable with the same ?token=
# (or Bearer). Leave unset to keep both the MCP endpoint open and the /api/*
# surface disabled (404). Generate:
#   openssl rand -hex 32
# METRO_MCP_HTTP_TOKEN=
# Log verbosity. One of: trace | debug | info | warn | error | fatal. Default: info.
# Logs go to stderr.
METRO_LOG_LEVEL=
