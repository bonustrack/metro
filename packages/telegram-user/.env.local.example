# Local-test creds for the telegram-user station. Copy to .env.local and fill in.
# .env.local is gitignored — these are full login credentials, never commit them.
# Used only by scripts/dev-local.ts, which boots an ISOLATED local daemon
# (throwaway state/trains/config dirs + a non-default webhook port). It never
# touches the real ~/.metro.

# From my.telegram.org → API development tools.
TELEGRAM_USER_API_ID=
TELEGRAM_USER_API_HASH=

# Serialized MTProto session string. Generate once, locally:
#   bun packages/telegram-user/scripts/login.ts
# Treat like a password — full login credential. Never commit or log it.
TELEGRAM_USER_SESSION=

# Optional: comma-separated allowlist restricting which accounts boot.
# TELEGRAM_USER_ONLY_ACCOUNTS=
